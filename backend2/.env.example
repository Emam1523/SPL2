APP_NAME=Backend2 API
APP_ENV=development
APP_DEBUG=true
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/lab_analytics
API_PREFIX=/api/v1
MAX_UPLOAD_MB=10
TESSERACT_CMD=
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174
AI_CONVERSATION_PROVIDER=ollama
AI_CONVERSATION_OLLAMA_URL=http://127.0.0.1:11434/api/chat
AI_CONVERSATION_OLLAMA_MODEL=llama3:8b
AI_CONVERSATION_GROQ_API_KEY=
AI_CONVERSATION_GROQ_MODEL=llama-3.3-70b-versatile
AI_CONVERSATION_GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
