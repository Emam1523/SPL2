# API Configuration
# If you need to override the backend API URL, uncomment and set this:
# VITE_API_URL=http://192.168.1.100:8080/api
# Optional WebSocket base URL when backend is on a different host:
# VITE_WS_URL=ws://192.168.1.100:8080

# By default, the app stays on the current origin, which works well for
# reverse proxies, tunnels, localhost, and public HTTPS demo links.
