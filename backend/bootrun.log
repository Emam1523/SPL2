Hibernate: 
    create table admin_logs (
        admin_id integer not null,
        log_id integer generated by default as identity,
        target_id integer,
        timestamp timestamp(6) not null,
        target_type varchar(50),
        action varchar(100) not null,
        description varchar(500),
        primary key (log_id)
    )
Hibernate: 
    create table admins (
        admin_id integer generated by default as identity,
        user_id integer not null unique,
        primary key (admin_id)
    )
Hibernate: 
    create table app_users (
        failed_login_attempts integer,
        is_active boolean,
        is_locked boolean,
        user_id integer generated by default as identity,
        created_at timestamp(6),
        last_login_attempt timestamp(6),
        lock_time timestamp(6),
        updated_at timestamp(6),
        phone_number varchar(15) unique,
        role varchar(50) not null check ((role in ('ADMIN','PATIENT','DOCTOR','ASSISTANT'))),
        email varchar(100) not null unique,
        first_name varchar(100) not null,
        last_name varchar(100) not null,
        password varchar(255) not null,
        primary key (user_id)
    )
Hibernate: 
    create table appointments (
        appointment_date date not null,
        appointment_id integer generated by default as identity,
        appointment_time time(0),
        doctor_id integer not null,
        patient_id integer not null,
        serial_number integer,
        code_expires_at timestamp(6),
        created_at timestamp(6) not null,
        updated_at timestamp(6),
        consultation_code varchar(10) unique,
        appointment_type varchar(20) not null check ((appointment_type in ('IN_PERSON','ONLINE'))),
        status varchar(20) not null check ((status in ('PENDING','CONFIRMED','SCHEDULED','REJECTED','CANCELLED','COMPLETED','NO_SHOW'))),
        cancellation_reason varchar(255),
        cancelled_by varchar(255),
        notes TEXT,
        rejection_reason varchar(255),
        primary key (appointment_id)
    )
Hibernate: 
    create table assistant_logs (
        assistant_id integer not null,
        doctor_id integer not null,
        entity_id integer,
        log_id integer generated by default as identity,
        created_at timestamp(6) not null,
        entity_type varchar(50),
        action varchar(100) not null,
        description TEXT,
        primary key (log_id)
    )
Hibernate: 
    create table assistants (
        assistant_id integer generated by default as identity,
        doctor_id integer,
        user_id integer not null unique,
        primary key (assistant_id)
    )
Hibernate: 
    create table doctors (
        consultation_fee float4,
        doctor_id integer generated by default as identity,
        user_id integer not null unique,
        year_of_experience integer,
        license_number varchar(50),
        specialization varchar(100),
        location varchar(255),
        primary key (doctor_id)
    )
Hibernate: 
    create table documents (
        document_id integer generated by default as identity,
        patient_id integer not null,
        file_size bigint not null,
        uploaded_at timestamp(6) not null,
        document_type varchar(255) not null check ((document_type in ('REPORT','PRESCRIPTION'))),
        file_name varchar(255) not null,
        file_url varchar(255) not null,
        primary key (document_id)
    )
Hibernate: 
    create table notifications (
        is_read boolean not null,
        notification_id integer generated by default as identity,
        related_entity_id integer,
        user_id integer not null,
        created_at timestamp(6) not null,
        related_entity_type varchar(50),
        type varchar(50) not null check ((type in ('APPOINTMENT_REQUEST','APPOINTMENT_CONFIRMED','APPOINTMENT_REJECTED','APPOINTMENT_CANCELLED','SYSTEM','REMINDER'))),
        message TEXT not null,
        title varchar(255) not null,
        primary key (notification_id)
    )
Hibernate: 
    create table patient_emergency_contacts (
